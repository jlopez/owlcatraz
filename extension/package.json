{
  "name": "owlcatraz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Owlcatraz — Chrome MV3 extension that exports your Duolingo vocabulary to an Anki deck for personal spaced-repetition study.",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "install:latest": "node scripts/install-latest.mjs",
    "install:pr": "node scripts/install-pr.mjs",
    "install:local": "node scripts/install-local.mjs"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@eslint/js": "^9.17.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "happy-dom": "^15.11.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
